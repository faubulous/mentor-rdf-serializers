{
  "name": "@faubulous/mentor-rdf-serializers",
  "description": "RDF 1.2 serializers for IDE use cases, optimized for code formatting and partial serialization.",
  "keywords": [
    "rdf",
    "rdf12",
    "serializer",
    "formatter",
    "turtle",
    "trig",
    "n3",
    "ntriples",
    "nquads",
    "jsonld",
    "sparql",
    "typescript"
  ],
  "version": "1.4.0",
  "private": false,
  "author": {
    "name": "Sebastian Faubel"
  },
  "license": "LGPL-2.1-or-later",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/faubulous/mentor-rdf-serializers.git"
  },
  "bugs": {
    "url": "https://github.com/faubulous/mentor-rdf-serializers/issues"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "bench": "vitest bench --run",
    "bench:stable": "vitest bench --run",
    "bench:baseline": "node scripts/run-bench-baseline.mjs",
    "bench:watch": "vitest bench",
    "build": "tsc",
    "check:pack": "npm pack --dry-run",
    "ci:quality": "npm run typecheck && npm test && npm run build && npm run check:pack",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@faubulous/mentor-rdf-parsers": "^1.7.1",
    "@rdfjs/data-model": "^2.1.0"
  },
  "devDependencies": {
    "@rdfjs/types": "^2.0.1",
    "@types/rdfjs__data-model": "^2.0.9",
    "@vitest/coverage-v8": "^4.0.18",
    "chevrotain": "^11.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@faubulous/mentor-rdf-parsers": "^1.4.0",
    "chevrotain": "^11.0.3"
  },
  "peerDependenciesMeta": {
    "@faubulous/mentor-rdf-parsers": {
      "optional": true
    },
    "chevrotain": {
      "optional": true
    }
  }
}
